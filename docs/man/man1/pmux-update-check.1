.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-update-check - Check release metadata without changing files


.SH SYNOPSIS
\fBpmux update check [flags]\fP


.SH DESCRIPTION
Check release metadata without changing files


.SH OPTIONS
\fB--component\fP="all"
	component: all, self, or proxy

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for check


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux-update(1)\fP
