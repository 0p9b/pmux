.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-opencode - Launch opencode with an exact model


.SH SYNOPSIS
\fBpmux opencode  [-- ] [flags]\fP


.SH DESCRIPTION
Launch opencode with an exact model


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for opencode


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux(1)\fP
