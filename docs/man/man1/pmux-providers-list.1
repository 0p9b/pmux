.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-providers-list - List providers


.SH SYNOPSIS
\fBpmux providers list [flags]\fP


.SH DESCRIPTION
List providers


.SH OPTIONS
\fB--enabled\fP=""
	filter by enabled state: true or false

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--refresh\fP[=false]
	refresh provider state

.PP
\fB--status\fP=""
	filter by status

.PP
\fB--type\fP=""
	filter by capability type


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux-providers(1)\fP
