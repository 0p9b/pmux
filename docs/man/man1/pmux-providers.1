.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-providers - Manage providers


.SH SYNOPSIS
\fBpmux providers [flags]\fP


.SH DESCRIPTION
Manage providers


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for providers


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux(1)\fP, \fBpmux-providers-disable(1)\fP, \fBpmux-providers-enable(1)\fP, \fBpmux-providers-list(1)\fP, \fBpmux-providers-login(1)\fP, \fBpmux-providers-remove(1)\fP, \fBpmux-providers-verify(1)\fP
