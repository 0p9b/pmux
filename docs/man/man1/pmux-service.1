.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-service - Manage CLIProxyAPI lifecycle


.SH SYNOPSIS
\fBpmux service [flags]\fP


.SH DESCRIPTION
Manage CLIProxyAPI lifecycle


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for service


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux(1)\fP, \fBpmux-service-install(1)\fP, \fBpmux-service-logs(1)\fP, \fBpmux-service-restart(1)\fP, \fBpmux-service-start(1)\fP, \fBpmux-service-status(1)\fP, \fBpmux-service-stop(1)\fP, \fBpmux-service-uninstall(1)\fP
