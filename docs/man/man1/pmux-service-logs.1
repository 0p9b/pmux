.nh
.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-service-logs - Read redacted service logs


.SH SYNOPSIS
\fBpmux service logs [flags]\fP


.SH DESCRIPTION
Read redacted service logs


.SH OPTIONS
\fB--clear\fP=""
	clear one supported upstream log source

.PP
\fB--follow\fP[=false]
	follow new entries

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for logs

.PP
\fB--level\fP=""
	filter by log level

.PP
\fB--lines\fP=100
	maximum initial log lines

.PP
\fB--output\fP=""
	write redacted logs to a private file

.PP
\fB--since\fP=""
	show logs since a time

.PP
\fB--source\fP="all"
	pmux, proxy, service, request-error, or all


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux-service(1)\fP
