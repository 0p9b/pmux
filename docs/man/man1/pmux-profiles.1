.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-profiles - Manage named launch profiles


.SH SYNOPSIS
\fBpmux profiles [flags]\fP


.SH DESCRIPTION
Manage named launch profiles


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for profiles


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux(1)\fP, \fBpmux-profiles-list(1)\fP, \fBpmux-profiles-remove(1)\fP, \fBpmux-profiles-set(1)\fP, \fBpmux-profiles-show(1)\fP
