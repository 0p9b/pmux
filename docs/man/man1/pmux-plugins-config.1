.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-plugins-config - Manage plugin configuration


.SH SYNOPSIS
\fBpmux plugins config [flags]\fP


.SH DESCRIPTION
Manage plugin configuration


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for config


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux-plugins(1)\fP, \fBpmux-plugins-config-set(1)\fP, \fBpmux-plugins-config-show(1)\fP
