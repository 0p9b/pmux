.nh
.TH "PMUX" "1" "Jul 2026" "PMux" "PMux Manual"

.SH NAME
pmux-launch - Launch a coding client


.SH SYNOPSIS
\fBpmux launch --client  --model  [-- ] [flags]\fP


.SH DESCRIPTION
Launch a coding client


.SH OPTIONS
\fB--client\fP=""
	coding client: claude, codex, gemini, or opencode

.PP
\fB--fallback\fP=[]
	exact fallback model IDs tried in order (comma-separated or repeatable)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for launch

.PP
\fB--model\fP=""
	exact dynamically discovered model ID

.PP
\fB--profile\fP=""
	named launch profile from \fBpmux profiles set\fR


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config-dir\fP=""
	override the PMux config root

.PP
\fB--json\fP[=false]
	emit machine-readable JSON or NDJSON

.PP
\fB--verbose\fP[=false]
	write safe diagnostic details to stderr

.PP
\fB--yes\fP[=false]
	accept the command's defined confirmation


.SH SEE ALSO
\fBpmux(1)\fP
